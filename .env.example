# ─────────────────────────────────────────────────────────────────────────────
#  KRAITIN — Environment Variables Reference
#  Copy this file to .env and fill in your values before deploying.
#  Never commit your actual .env to git — it's in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Internal app identifier (used by platform tooling, safe to leave as-is)
VITE_APP_ID=your-app-id


# ── Supabase Edge Function Secrets ────────────────────────────────────────────
# Set these via: supabase secrets set KEY=value
# Or in Supabase Dashboard → Edge Functions → Secrets
#
# Auto-injected by Supabase runtime — do NOT set manually:
#   SUPABASE_URL
#   SUPABASE_ANON_KEY
#   SUPABASE_SERVICE_ROLE_KEY
#
# Comma-separated list of allowed frontend origins (e.g. https://kraitin.com,http://localhost:5173)
ALLOWED_ORIGINS=https://your-app-domain.com,http://localhost:5173


# ── Stripe ────────────────────────────────────────────────────────────────────
# Found in: Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...

# Found in: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
# Endpoint to register: https://your-project-ref.supabase.co/functions/v1/stripe-webhook
# Events to enable: checkout.session.completed, customer.subscription.updated,
#   customer.subscription.deleted, invoice.paid, invoice.payment_succeeded, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...

# Found in: Stripe Dashboard → Products → your Pro product → Prices
# Create two recurring prices: one monthly ($49), one yearly ($490)
STRIPE_MONTHLY_PRICE_ID=price_...
STRIPE_YEARLY_PRICE_ID=price_...


# ── Resend (Transactional Email) ──────────────────────────────────────────────
# Found in: https://resend.com/api-keys
# Used for: welcome email on first activation, credits-reset email on renewal
RESEND_API_KEY=re_...


# ── AI / LLM (Platform-managed — do NOT expose to client) ────────────────────
# Injected automatically by the Miaoda platform integration layer.
# If self-hosting, obtain from Google AI Studio: https://aistudio.google.com/app/apikey
INTEGRATIONS_API_KEY=your_integrations_api_key_here


# ── The News API ──────────────────────────────────────────────────────────────
# Found in: https://www.thenewsapi.com → Dashboard → API Token
# Used by: all-news edge function
THE_NEWS_API_KEY=your_the_news_api_key_here
